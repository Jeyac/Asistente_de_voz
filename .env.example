# --- Aplicación ---
APP_NAME=Asistente de Voz API
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
ENABLE_DOCS=true
API_DESCRIPTION=API REST del asistente de voz profesional

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- CORS (separar orígenes por coma) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_SLOW_REQUEST_MS=1000
LOG_REQUEST_BODY=false
LOG_TO_FILE=true

# --- Rutas de datos y modelos (relativas a la raíz del proyecto) ---
DATA_DIR=data
INTENTS_DATASET_PATH=data/intents/intents_dataset.json
RESPONSES_DATA_PATH=data/responses/responses.json
TENSORFLOW_MODELS_DIR=models/tensorflow

# --- Acciones del sistema (solo local; en Render el frontend abre URLs) ---
ENABLE_SYSTEM_ACTIONS=true
CREATOR_NAME=Jéraldyn
CREATOR_DISPLAY_TITLE=la hermosa, inteligente, capaz, independiente, empoderada y maravillosa
PARTNER_NAME=Kevin Estrada
PARTNER_DISPLAY_TITLE=su guapo, precioso, hermoso, maravilloso e increíble novio

# --- SpeechRecognition ---
SPEECH_RECOGNITION_LANGUAGE=es-ES
SPEECH_RECOGNITION_TIMEOUT=5
SPEECH_RECOGNITION_PHRASE_LIMIT=10
SPEECH_AMBIENT_NOISE_DURATION=0.5
SPEECH_POST_WAKEWORD_PAUSE=1.0
SPEECH_POST_WAKEWORD_TIMEOUT=8
SPEECH_POST_WAKEWORD_PHRASE_LIMIT=12
SPEECH_POST_WAKEWORD_AMBIENT_DURATION=1.2
SPEECH_MAX_AUDIO_BYTES=5242880
SPEECH_ALLOWED_FORMATS=wav,wave

# --- Palabra clave (wake word) ---
WAKEWORD_ENABLED=true
WAKEWORD_ENGINE=openwakeword
WAKEWORD_PHRASE=hey jarvis
WAKEWORD_MODEL_PATH=models/wakeword/hey_jarvis_v0.1.onnx
WAKEWORD_THRESHOLD=0.5
WAKEWORD_LISTEN_TIMEOUT=60
WAKEWORD_CHUNK_DURATION_MS=80
PORCUPINE_ACCESS_KEY=
PORCUPINE_KEYWORD_PATH=models/wakeword/oye_sistema_es_windows.ppn

# --- spaCy (incluido en requirements.txt; modelo se descarga con: python -m spacy download es_core_news_sm) ---
SPACY_MODEL=es_core_news_sm

# --- TensorFlow / Clasificador de intenciones ---
TF_MODEL_FILENAME=intent_classifier.keras
TF_TOKENIZER_FILENAME=tokenizer.json
TF_LABELS_FILENAME=labels.json
TF_METADATA_FILENAME=training_metadata.json
TF_CONFIDENCE_THRESHOLD=0.75
TF_FALLBACK_INTENT=desconocido
TF_MAX_VOCAB_SIZE=2000
TF_SEQUENCE_LENGTH=20
TF_EMBEDDING_DIM=64
TF_EPOCHS=80
TF_BATCH_SIZE=8
TF_VALIDATION_SPLIT=0.2
TF_LEARNING_RATE=0.001
